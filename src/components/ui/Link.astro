---
import { cn } from '@/utils'
import type { HTMLAttributes } from 'astro/types'

const TEXT_LINK_BASE =
  "[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-[0.04em] text-[var(--text-muted)] no-underline transition-colors duration-200 hover:text-[var(--text)]"

const VARIANTS = {
  default: TEXT_LINK_BASE,
  text: TEXT_LINK_BASE,
  gradient: TEXT_LINK_BASE,
  rounded:
    'inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-4 py-1.5 text-[0.8125rem] font-medium text-[var(--text-secondary)] no-underline transition-colors duration-200 hover:border-[var(--border)] hover:bg-[var(--border)]',
}

type Props = HTMLAttributes<'a'> & {
  variant?: keyof typeof VARIANTS
}

const { variant = 'default', ...props } = Astro.props as Props

const className = cn(VARIANTS[variant], props.class ?? '')
---

<a href={props.href} class={className} {...props}>
  <slot />
</a>
