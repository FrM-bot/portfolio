---
import { getI18n } from '@/i18n'
import { formatDate } from '@/utils'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const experience = i18n.Experience
const presentLabel = i18n.Translations.words.present
const title = i18n.Translations.sections.title.Experience

const formatWork = (work: string[]) =>
  work.join(' · ').replace(/\s*\|\s*/g, ' · ')
---

<article class="flex flex-col gap-8">
  <header class="flex flex-col gap-2.5">
    <span
      class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-[0.1em] text-[var(--text-faint)] uppercase"
    >
      {title}
    </span>
    <span class="block h-px w-full bg-[var(--border)]"></span>
  </header>

  <ol class="m-0 flex list-none flex-col gap-4 p-0">
    {
      experience.map(({ position, company, location, date, work }, i) => (
        <li class="-mx-3 grid grid-cols-1 gap-3 border-b border-[var(--border)] px-3 pt-4 pb-[1.35rem] first:pt-0 sm:mx-0 sm:grid-cols-[3rem_minmax(0,1fr)] sm:gap-4 sm:px-0">
          <div
            class="flex flex-row items-center gap-3 pt-0 sm:flex-col sm:items-start sm:gap-[0.65rem] sm:pt-[0.15rem]"
            aria-hidden="true"
          >
            <span class="inline-flex min-h-6 items-center justify-center text-[0.625rem] font-normal tracking-[0.06em] text-[var(--accent)] [font-variant-numeric:tabular-nums]">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="block h-px w-full flex-1 bg-[var(--border)] sm:h-auto sm:w-px" />
          </div>

          <div class="flex min-w-0 flex-col gap-[0.8rem]">
            <div class="flex flex-col items-start justify-between gap-[0.875rem] sm:flex-row sm:flex-wrap sm:gap-x-5">
              <div class="flex min-w-0 flex-col gap-[0.15rem]">
                <p class="text-xs leading-[1.45] font-medium tracking-[0.08em] text-[var(--text-faint)] uppercase">
                  {position}
                </p>
                <h3 class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[clamp(1.1rem,0.35vw+1rem,1.3rem)] leading-[1.08] font-medium text-[var(--text)]">
                  {company}
                </h3>
              </div>

              <span class="inline-flex shrink-0 items-center rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-3.5 py-[0.35rem] text-[0.6875rem] font-medium whitespace-normal text-[var(--text-muted)] [font-variant-numeric:tabular-nums] sm:whitespace-nowrap">
                {formatDate(new Date(date.from), { locales: currentLocale })} —{' '}
                {date?.to
                  ? formatDate(new Date(date.to), { locales: currentLocale })
                  : presentLabel}
              </span>
            </div>

            <p class="flex flex-wrap items-center gap-x-4 gap-y-[0.65rem] text-sm leading-[1.65] text-[var(--text-muted)]">
              <span class="text-[var(--text)]">{location.country}</span>
              {work.length > 0 && (
                <span class="max-w-[62ch] text-[var(--text-faint)]">
                  {formatWork(work)}
                </span>
              )}
            </p>
          </div>
        </li>
      ))
    }
  </ol>
</article>
