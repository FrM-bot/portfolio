---
import { getI18n } from '@/i18n'
import SocialLinks from './SocialLinks.astro'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const contact = i18n.Contact
const title = i18n.Translations.sections.title.Contact
---

<section class="contact-section">
  <header class="section-header">
    <span class="section-label">{title}</span>
    <span class="h-rule"></span>
  </header>

  <div class="contact-body">
    <address class="contact-address" set:html={contact.message} />
    <div class="contact-socials">
      <SocialLinks />
    </div>
  </div>
</section>

<style>
  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .contact-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-address {
    font-style: normal;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #737373;
    max-width: 56ch;
  }

  .contact-address :global(.text-link) {
    font-weight: 500;
  }

  .contact-socials {
    padding-top: 0.25rem;
  }
</style>
