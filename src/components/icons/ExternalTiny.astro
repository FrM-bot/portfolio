---
import { cn } from '@/utils'

interface Props {
  class?: string
  size?: number
}

const { class: className, size = 12 } = Astro.props as Props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 12 12"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cn('shrink-0', className ?? '')}
  aria-hidden="true"
>
  <path d="M3 9L9 3"></path>
  <path d="M4.5 3H9V7.5"></path>
</svg>
