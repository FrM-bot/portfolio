---
import SocialLinks from './SocialLinks.astro'
import { convertAsteriskToStrongTag } from '@/utils'
import Link from './ui/Link.astro'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro

const i18n = getI18n({ lang: currentLocale })

const presentation = i18n.Presentation

const greeting = i18n.Presentation.greeting
const status = i18n.Presentation.status
---

<article
  class="flex flex-col gap-8 md:flex-row-reverse md:justify-end lg:gap-16"
>
  {
    presentation.profile && (
      <div class="pres-avatar-wrap flex h-full flex-col items-center gap-3">
        <picture class="pres-avatar">
          <img
            class="rounded-full"
            width="180"
            height="180"
            src={presentation.profile}
            alt="GitHub profile"
          />
        </picture>
        <Link
          variant="rounded"
          href={presentation.curriculum.link}
          target="_blank"
        >
          {presentation.curriculum.label}
        </Link>
      </div>
    )
  }

  <div class="flex flex-col gap-5">
    <div class="flex flex-col gap-1">
      <p class="pres-greeting">{greeting}</p>
      <h1 class="pres-name">{presentation.title}</h1>
    </div>

    {
      status && (
        <div class="status-badge">
          <span class="status-dot" aria-hidden="true" />
          <span>{status}</span>
        </div>
      )
    }

    <h2
      class="pres-desc"
      set:html={convertAsteriskToStrongTag(presentation.description)}
    />

    <div class="pres-socials">
      <SocialLinks />
    </div>
  </div>
</article>

<style>
  .pres-greeting {
    font-size: 0.875rem;
    color: var(--text-faint);
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.1s;
  }

  .pres-name {
    font-family: 'Jost', ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(3rem, 10vw + 0.5rem, 6.5rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--text);
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.2s;
  }

  .pres-desc {
    max-width: 60ch;
    line-height: 1.7;
    color: var(--text-muted);
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.35s;
  }

  .pres-desc :global(strong) {
    color: var(--text);
    font-weight: 500;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    background-color: var(--border);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.01em;
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.28s;
    width: fit-content;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--accent);
    flex-shrink: 0;
    animation: status-pulse 2.5s ease-in-out infinite;
  }

  .pres-socials {
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.48s;
  }

  .pres-avatar-wrap {
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.15s;
  }

  .pres-avatar {
    display: block;
    border-radius: 9999px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-greeting,
    .pres-name,
    .pres-desc,
    .pres-socials,
    .pres-avatar-wrap,
    .status-badge,
    .status-dot {
      animation: none;
    }
  }
</style>
