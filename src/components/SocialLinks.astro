---
import { getI18n } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const { socials } = i18n.Presentation
---

<ul role="list" class="m-0 flex list-none flex-wrap gap-2 p-0">
  {
    socials.map((social) => (
      <li>
        <a
          href={social.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-3.5 py-1.5 text-[0.8125rem] font-medium tracking-[0.01em] text-[var(--text-secondary)] no-underline transition-colors duration-200 hover:border-[var(--border)] hover:bg-[var(--border)]"
        >
          {social.label} ↗
        </a>
      </li>
    ))
  }
</ul>
