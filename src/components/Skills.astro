---
import { skills } from '@/data/skills'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const title = i18n.Translations.sections.title.Skills
const skillTitles = i18n.Skills

const formatLabel = (label: string) => label.replace(/\.$/, '')

const rows = [
  { label: formatLabel(skillTitles.languages.label), items: skills.languages },
  {
    label: formatLabel(skillTitles.frameworks.label),
    items: skills.frameworks,
  },
  { label: formatLabel(skillTitles.libraries.label), items: skills.libraries },
  { label: formatLabel(skillTitles.orms.label), items: skills.orms },
  { label: formatLabel(skillTitles.dbs.label), items: skills.dbs },
  { label: formatLabel(skillTitles.other.label), items: skills.other },
]
---

<article class="flex flex-col gap-3">
  <header class="flex flex-col gap-2.5">
    <span
      class="font-['Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-widest text-(--text-faint) uppercase"
    >
      {title}
    </span>
  </header>

  <dl class="m-0 flex flex-col gap-0">
    {
      rows.map(({ label, items }, rowIndex) => (
        <div
          class="group first:border-t-none grid [animation:fade-up_.55s_cubic-bezier(0.16,1,0.3,1)_both] grid-cols-1 items-start gap-y-2 border-t border-(--border) py-3 transition duration-200 last:border-b hover:bg-[color-mix(in_oklch,var(--bg-subtle)_60%,transparent)] motion-reduce:animate-none motion-reduce:transition-none min-[561px]:grid-cols-[auto_minmax(0,1fr)] min-[561px]:gap-x-10 min-[561px]:gap-y-0"
          style={`animation-delay: ${0.08 * rowIndex}s`}
        >
          <dt class="pt-0 font-['Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-widest whitespace-nowrap text-(--text-muted) uppercase transition-transform duration-200 group-hover:translate-x-0.5 motion-reduce:transition-none min-[561px]:pt-[0.2rem]">
            {label}
          </dt>
          <dd class="m-0 flex flex-wrap items-center gap-1.5 text-[0.875rem] leading-[1.55]">
            {items.map((skill) => (
              <span class="inline-flex cursor-default items-center rounded-full border border-transparent bg-transparent px-2 py-0.5 text-(--text-secondary) transition duration-200 hover:border-(--border) hover:bg-(--bg-subtle) hover:text-(--text) motion-reduce:transition-none">
                {skill}
              </span>
            ))}
          </dd>
        </div>
      ))
    }
  </dl>
</article>
