---
import { cn } from '@/utils'
import type { HTMLAttributes } from 'astro/types'

const VARIANTS = {
  default: 'link-default',
  text: 'link-text',
  gradient: 'link-underline',
  rounded: 'link-rounded',
}

type Props = HTMLAttributes<'a'> & {
  variant?: keyof typeof VARIANTS
}

const { variant = 'default', ...props } = Astro.props as Props

const className = cn(VARIANTS[variant], props.class ?? '')
---

<a href={props.href} class={className} {...props}>
  <slot />
</a>

<style>
  .link-default {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .link-default:hover {
    color: var(--text);
  }

  .link-text {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .link-text:hover {
    color: var(--accent);
  }

  .link-underline {
    position: relative;
    color: var(--text-muted);
    padding-bottom: 0.125rem;
    transition: color 0.2s ease;
  }
  .link-underline::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .link-underline:hover {
    color: var(--text);
  }
  .link-underline:hover::after {
    transform: scaleX(1);
  }

  .link-rounded {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 1rem;
    border: 1px solid var(--border);
    border-radius: 2rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .link-rounded:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }
</style>
