{
  "name": "frm-bot-portfolio",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/onest": "5.2.11",
    "@fontsource/jost": "5.2.8",
    "@fontsource/manrope": "5.2.8",
    "astro": "6.1.9",
