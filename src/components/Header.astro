---
import Link from './ui/Link.astro'
import { Languages, getI18n } from '@/i18n'

const { currentLocale } = Astro

const NavigationLinks = [
  {
    label: Languages.ENGLISH,
    href: '/',
  },
  {
    label: Languages.SPANISH,
    href: `/${Languages.SPANISH}`,
  },
]

const i18n = getI18n({ lang: currentLocale })

const presentation = i18n.Presentation
---

<header class="hdr flex w-full items-center justify-between">
  <Link target="_blank" variant="text" href={`mailto:${presentation.mail}`}
    >{presentation.mail}</Link
  >
  <nav role="navigation">
    <ul role="list" class="flex flex-row items-center gap-2">
      {
        NavigationLinks.map((lang) => {
          const isCurrent = lang.label === currentLocale
          return (
            <li>
              <a
                href={lang.href}
                class={`lang-tab${isCurrent ? ' lang-tab--active' : ''}`}
              >
                {lang.label.toLocaleUpperCase()}
              </a>
            </li>
          )
        })
      }
    </ul>
  </nav>
</header>

<style>
  .hdr {
    animation: fade-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .lang-tab {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #737373;
    text-decoration: none;
  }

  .lang-tab--active {
    background-color: #e5e5e5;
    color: #262626;
  }
</style>
