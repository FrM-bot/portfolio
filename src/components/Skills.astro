---
import { skills } from '@/data/skills'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const title = i18n.Translations.sections.title.Skills
const skillTitles = i18n.Skills

const formatLabel = (label: string) => label.replace(/\.$/, '')

const rows = [
  { label: formatLabel(skillTitles.languages.label), items: skills.languages },
  {
    label: formatLabel(skillTitles.frameworks.label),
    items: skills.frameworks,
  },
  { label: formatLabel(skillTitles.libraries.label), items: skills.libraries },
  { label: formatLabel(skillTitles.orms.label), items: skills.orms },
  { label: formatLabel(skillTitles.dbs.label), items: skills.dbs },
  { label: formatLabel(skillTitles.other.label), items: skills.other },
]
---

<article class="flex flex-col gap-2">
  <header class="flex flex-col gap-2.5">
    <span
      class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-[0.1em] text-[var(--text-faint)] uppercase"
    >
      {title}
    </span>
  </header>

  <dl class="m-0 flex flex-col gap-0">
    {
      rows.map(({ label, items }) => (
        <div class="grid grid-cols-1 items-start gap-y-1.5 border-t border-[var(--border)] py-3 last:border-b min-[561px]:grid-cols-[auto_minmax(0,1fr)] min-[561px]:gap-x-10 min-[561px]:gap-y-0">
          <dt class="pt-0 [font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-[0.1em] whitespace-nowrap text-[var(--text-muted)] uppercase min-[561px]:pt-[0.2rem]">
            {label}
          </dt>
          <dd class="m-0 text-[0.9375rem] leading-[1.65]">
            {items.map((skill, i) => (
              <>
                <span class="cursor-default text-[var(--text-secondary)]">
                  {skill}
                </span>
                {i < items.length - 1 && (
                  <span
                    class="pointer-events-none text-[var(--text-faint)] select-none"
                    aria-hidden="true"
                  >
                    {' '}
                    ·{' '}
                  </span>
                )}
              </>
            ))}
          </dd>
        </div>
      ))
    }
  </dl>
</article>
