---
import ProjectCard from '@/components/card/Project.astro'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const projects = i18n.Projects
const title = i18n.Translations.sections.title.Projects

const featured = projects.filter((p) => p.highlight)
const regular = projects.filter((p) => !p.highlight)

const formatTechs = (values: string[], max = 3) =>
  values.slice(0, max).join(' · ') + (values.length > max ? ' …' : '')
---

<article class="projects-section">
  <header class="section-header">
    <span class="section-label">{title}</span>
    <span class="h-rule"></span>
  </header>

  {
    featured.length > 0 && (
      <div class="featured-grid">
        {featured.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    )
  }

  {
    regular.length > 0 && (
      <div class="regular-list">
        {regular.map((project, i) => (
          <div class="proj-row">
            <span class="row-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="row-title">{project.title}</span>
            <span class="row-techs">{formatTechs(project.techs)}</span>
            <div class="row-links">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="row-link"
                  aria-label={`${project.title} on GitHub`}
                >
                  GH ↗
                </a>
              )}
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="row-link"
                  aria-label={`Visit ${project.title}`}
                >
                  Visit ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )
  }
</article>

<style>
  .projects-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }

  .regular-list {
    display: flex;
    flex-direction: column;
  }

  .proj-row {
    display: grid;
    grid-template-columns: 2rem 1fr 1fr auto;
    align-items: baseline;
    gap: 0 1rem;
    padding: 0.625rem 0;
    border-top: 1px solid #e5e5e5;
  }

  .proj-row:last-child {
    border-bottom: 1px solid #e5e5e5;
  }

  @media (max-width: 580px) {
    .proj-row {
      grid-template-columns: 2rem 1fr auto;
    }
    .row-techs {
      display: none;
    }
  }

  .row-num {
    font-size: 0.625rem;
    color: #a3a3a3;
    font-variant-numeric: tabular-nums;
    font-weight: 400;
    letter-spacing: 0.04em;
    padding-top: 0.1rem;
  }

  .row-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #000000;
  }

  .row-title:hover {
    color: #525252;
  }

  .row-techs {
    font-size: 0.75rem;
    color: #a3a3a3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .row-link {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    border: 1px solid #e5e5e5;
    background-color: #ffffff;
    font-size: 0.625rem;
    font-weight: 500;
    color: #262626;
    text-decoration: none;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .row-link:hover {
    background-color: #e5e5e5;
  }
</style>
