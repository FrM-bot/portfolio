---
import ProjectCard from '@/components/card/Project.astro'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const projects = i18n.Projects
const title = i18n.Translations.sections.title.Projects

const featured = projects.filter((p) => p.highlight)
const regular = projects.filter((p) => !p.highlight)

const formatTechs = (values: string[], max = 3) =>
  values.slice(0, max).join(' · ') + (values.length > max ? ' …' : '')
---

<article class="flex flex-col gap-8">
  <header class="flex flex-col gap-2.5">
    <span
      class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-[0.1em] text-[var(--text-faint)] uppercase"
    >
      {title}
    </span>
    <span class="block h-px w-full bg-[var(--border)]"></span>
  </header>

  {
    featured.length > 0 && (
      <div class="grid grid-cols-1 gap-3 min-[601px]:grid-cols-3">
        {featured.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    )
  }

  {
    regular.length > 0 && (
      <div class="flex flex-col">
        {regular.map((project, i) => (
          <div class="grid grid-cols-[2rem_minmax(0,1fr)_auto] items-baseline gap-x-4 border-t border-[var(--border)] py-2.5 last:border-b min-[581px]:grid-cols-[2rem_minmax(0,1fr)_minmax(0,1fr)_auto]">
            <span class="pt-[0.1rem] text-[0.625rem] font-normal tracking-[0.04em] text-[var(--accent)] [font-variant-numeric:tabular-nums]">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-[0.9375rem] font-medium text-[var(--text)] transition-colors duration-200 hover:text-[var(--text-muted)]">
              {project.title}
            </span>
            <span class="hidden overflow-hidden text-xs text-ellipsis whitespace-nowrap text-[var(--text-faint)] min-[581px]:block">
              {formatTechs(project.techs)}
            </span>
            <div class="flex items-center gap-2">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-2.5 py-[0.2rem] text-[0.625rem] font-medium tracking-[0.03em] whitespace-nowrap text-[var(--text-secondary)] no-underline transition-colors duration-200 hover:bg-[var(--border)]"
                  aria-label={`${project.title} on GitHub`}
                >
                  GH ↗
                </a>
              )}
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-2.5 py-[0.2rem] text-[0.625rem] font-medium tracking-[0.03em] whitespace-nowrap text-[var(--text-secondary)] no-underline transition-colors duration-200 hover:bg-[var(--border)]"
                  aria-label={`Visit ${project.title}`}
                >
                  Visit ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )
  }
</article>
