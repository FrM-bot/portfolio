---
import Link from './ui/Link.astro'
import { Languages, getI18n } from '@/i18n'

const { currentLocale } = Astro

const NavigationLinks = [
  {
    label: Languages.ENGLISH,
    href: '/',
  },
  {
    label: Languages.SPANISH,
    href: `/${Languages.SPANISH}`,
  },
]

const i18n = getI18n({ lang: currentLocale })

const presentation = i18n.Presentation
---

<header class="hdr flex w-full items-center justify-between">
  <Link target="_blank" variant="text" href={`mailto:${presentation.mail}`}
    >{presentation.mail}</Link
  >
  <div class="hdr-right">
    <nav>
      <ul role="list" class="flex flex-row items-center gap-4">
        {
          NavigationLinks.map((lang) => {
            const isCurrent = lang.label === currentLocale
            return (
              <li>
                <a
                  href={lang.href}
                  aria-current={isCurrent ? 'page' : undefined}
                  class={`lang-tab${isCurrent ? ' lang-tab--active' : ''}`}
                >
                  {lang.label.toLocaleUpperCase()}
                </a>
              </li>
            )
          })
        }
      </ul>
    </nav>
    <button class="theme-toggle" id="theme-toggle" type="button">
      <span class="theme-label">DARK</span>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle')
  const label = toggle?.querySelector('.theme-label')

  const apply = (theme: string) => {
    document.documentElement.setAttribute('data-theme', theme)
    localStorage.setItem('theme', theme)
    if (label) label.textContent = theme === 'dark' ? 'LIGHT' : 'DARK'
  }

  apply(document.documentElement.getAttribute('data-theme') || 'light')

  toggle?.addEventListener('click', () => {
    const current =
      document.documentElement.getAttribute('data-theme') || 'light'
    apply(current === 'dark' ? 'light' : 'dark')
  })
</script>

<style>
  .hdr {
    animation: fade-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hdr-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .lang-tab {
    font-family: 'Jost', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .lang-tab:hover {
    color: var(--text-muted);
  }

  .lang-tab--active {
    color: var(--text);
  }

  .theme-toggle {
    font-family: 'Jost', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  .theme-toggle:hover {
    color: var(--text-muted);
  }
</style>
