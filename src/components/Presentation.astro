---
import SocialLinks from './SocialLinks.astro'
import { convertAsteriskToStrongTag } from '@/utils'
import Link from './ui/Link.astro'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro

const i18n = getI18n({ lang: currentLocale })

const presentation = i18n.Presentation

const greeting = i18n.Presentation.greeting
---

<article
  class="flex flex-col gap-8 md:flex-row-reverse md:justify-end lg:gap-16"
>
  {
    presentation.profile && (
      <div class="pres-avatar-wrap flex h-full flex-col items-center gap-3">
        <picture class="pres-avatar">
          <img
            class="rounded-full"
            width="180"
            height="180"
            src={presentation.profile}
            alt="GitHub profile"
          />
        </picture>
        <Link
          variant="text"
          href={presentation.curriculum.link}
          target="_blank"
        >
          {presentation.curriculum.label}
        </Link>
      </div>
    )
  }

  <div class="flex flex-col gap-5">
    <div class="flex flex-col gap-1">
      <p class="pres-greeting">{greeting}</p>
      <h1 class="pres-name">{presentation.title}</h1>
    </div>

    <h2
      class="pres-desc"
      set:html={convertAsteriskToStrongTag(presentation.description)}
    />

    <div class="pres-socials">
      <SocialLinks />
    </div>
  </div>
</article>

<style>
  .pres-greeting {
    font-size: 0.875rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.1s;
  }

  .pres-name {
    font-family: 'Jost', sans-serif;
    font-size: clamp(3rem, 10vw + 0.5rem, 6.5rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--text);
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.2s;
  }

  .pres-desc {
    max-width: 60ch;
    line-height: 1.7;
    color: var(--text-muted);
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.35s;
  }

  .pres-desc :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .pres-socials {
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.48s;
  }

  .pres-avatar-wrap {
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.15s;
  }

  .pres-avatar {
    display: block;
    border-radius: 9999px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color 0.2s ease;
  }

  .pres-avatar:hover {
    border-color: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-greeting,
    .pres-name,
    .pres-desc,
    .pres-socials,
    .pres-avatar-wrap {
      animation: none;
    }
  }
</style>
