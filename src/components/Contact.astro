---
import { getI18n } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const contact = i18n.Contact
const title = i18n.Translations.sections.title.Contact
---

<section class="contact-section">
  <header class="section-header">
    <span class="section-label">{title}</span>
    <span class="h-rule"></span>
  </header>

  <address class="contact-address" set:html={contact.message} />
</section>

<style>
  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .contact-address {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-muted);
  }
</style>
