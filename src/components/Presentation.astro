---
import SocialLinks from './SocialLinks.astro'
import { convertAsteriskToStrongTag } from '@/utils'
import Link from './ui/Link.astro'
import { getI18n } from '@/i18n'

const { currentLocale } = Astro

const i18n = getI18n({ lang: currentLocale })

const presentation = i18n.Presentation

const greeting = i18n.Presentation.greeting
const status = i18n.Presentation.status
---

<article
  class="flex flex-col gap-10 md:flex-row-reverse md:items-start md:justify-end lg:gap-16"
>
  {
    presentation.profile && (
      <div class="flex h-full [animation:fade-up_.7s_cubic-bezier(0.16,1,0.3,1)_both] flex-col items-center gap-3 [animation-delay:.15s] motion-reduce:animate-none">
        <picture class="block overflow-hidden rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] p-1">
          <img
            class="rounded-full saturate-[0.92]"
            width="180"
            height="180"
            src={presentation.profile}
            alt="GitHub profile"
          />
        </picture>
        <Link
          variant="rounded"
          href={presentation.curriculum.link}
          target="_blank"
        >
          {presentation.curriculum.label}
        </Link>
      </div>
    )
  }

  <div class="flex max-w-[68ch] flex-col gap-6">
    <div class="flex flex-col gap-1">
      <p
        class="[animation:fade-up_.6s_cubic-bezier(0.16,1,0.3,1)_both] text-sm text-[var(--text-faint)] [animation-delay:.1s] motion-reduce:animate-none"
      >
        {greeting}
      </p>
      <h1
        class="[animation:fade-up_.7s_cubic-bezier(0.16,1,0.3,1)_both] [font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[clamp(3rem,10vw+0.5rem,6.5rem)] leading-[1.06] font-extrabold tracking-[-0.03em] text-[var(--text)] [animation-delay:.2s] motion-reduce:animate-none"
      >
        {presentation.title}
      </h1>
    </div>

    {
      status && (
        <div class="inline-flex w-fit [animation:fade-up_.6s_cubic-bezier(0.16,1,0.3,1)_both] items-center gap-2 rounded-full bg-[var(--border)] px-3.5 py-1.5 text-xs font-medium tracking-[0.01em] text-[var(--text-secondary)] [animation-delay:.28s] motion-reduce:animate-none">
          <span
            class="h-1.5 w-1.5 shrink-0 [animation:status-pulse_2.5s_ease-in-out_infinite] rounded-full bg-[var(--accent)] motion-reduce:animate-none"
            aria-hidden="true"
          />
          <span>{status}</span>
        </div>
      )
    }

    <h2
      class="max-w-[65ch] [animation:fade-up_.7s_cubic-bezier(0.16,1,0.3,1)_both] text-[1.03125rem] leading-[1.72] text-[var(--text-muted)] [animation-delay:.35s] motion-reduce:animate-none [&_strong]:font-medium [&_strong]:text-[var(--text)]"
      set:html={convertAsteriskToStrongTag(presentation.description)}
    />

    <div
      class="[animation:fade-up_.6s_cubic-bezier(0.16,1,0.3,1)_both] [animation-delay:.48s] motion-reduce:animate-none"
    >
      <SocialLinks />
    </div>
  </div>
</article>
