---
import type { Project } from '@/data/projects'

type Props = Project

const { title, techs, link, github, description } = Astro.props as Props

const formatTechs = (values: string[]) => values.join(' · ')
---

<article
  class="flex h-full min-h-[200px] flex-col rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)]"
>
  <div class="flex h-full flex-col justify-between gap-6 p-6">
    <div class="flex flex-col gap-1.5">
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-base leading-[1.2] font-medium text-[var(--text)] no-underline transition-colors duration-200 hover:text-[var(--text-muted)]"
      >
        {title}
      </a>
      <p class="text-[0.6875rem] leading-[1.5] text-[var(--text-faint)]">
        {formatTechs(techs)}
      </p>
      {
        description && (
          <p class="mt-1.5 text-[0.8125rem] leading-[1.55] text-[var(--text-muted)]">
            {description}
          </p>
        )
      }
    </div>

    <div class="flex flex-wrap items-center gap-2">
      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg)] px-3 py-1 text-[0.6875rem] font-medium tracking-[0.02em] text-[var(--text-secondary)] no-underline transition-colors duration-200 hover:border-[var(--border)] hover:bg-[var(--border)]"
            aria-label={`${title} on GitHub`}
          >
            GitHub ↗
          </a>
        )
      }
      {
        link && (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg)] px-3 py-1 text-[0.6875rem] font-medium tracking-[0.02em] text-[var(--text-secondary)] no-underline transition-colors duration-200 hover:border-[var(--border)] hover:bg-[var(--border)]"
            aria-label={`Visit ${title}`}
          >
            Visit ↗
          </a>
        )
      }
    </div>
  </div>
</article>
