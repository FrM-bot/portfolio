---
import type { Project } from '@/data/projects'

type Props = Project

const { title, techs, link, github, image, description } = Astro.props as Props

const formatTechs = (values: string[]) => values.join(' · ')
---

<article class="proj-card">
  {image && <img loading="lazy" src={image} alt={title} class="proj-bg" />}

  <div class="proj-overlay" aria-hidden="true"></div>

  <div class="proj-content">
    <div class="proj-top">
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="proj-title"
      >
        {title}
      </a>
      <p class="proj-techs">{formatTechs(techs)}</p>
      {description && <p class="proj-desc">{description}</p>}
    </div>

    <div class="proj-links">
      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="proj-link"
            aria-label={`${title} on GitHub`}
          >
            GitHub ↗
          </a>
        )
      }
      {
        link && (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="proj-link"
            aria-label={`Visit ${title}`}
          >
            Visit ↗
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .proj-card {
    position: relative;
    overflow: hidden;
    background-color: var(--bg-subtle);
    height: 100%;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    /* Inset shadow simulates border; grid gap provides separation at rest */
    box-shadow: inset 0 0 0 0 var(--accent);
    transition:
      box-shadow 0.25s ease,
      transform 0.2s ease;
  }

  .proj-card:hover {
    box-shadow: inset 0 0 0 1px var(--accent);
    transform: translateY(-2px);
  }

  .proj-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
    transition: opacity 0.35s ease;
    z-index: 0;
    pointer-events: none;
  }

  .proj-card:hover .proj-bg {
    opacity: 0.5;
  }

  /* Bottom gradient keeps text readable over image */
  .proj-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--bg-subtle) 30%, transparent 100%);
    z-index: 1;
    pointer-events: none;
  }

  .proj-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: 1.25rem;
    gap: 1.5rem;
  }

  .proj-top {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .proj-title {
    font-family: 'Jost', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    transition: color 0.2s ease;
  }
  .proj-title:hover {
    color: var(--accent);
  }

  .proj-techs {
    font-size: 0.6875rem;
    color: var(--text-faint);
    line-height: 1.5;
  }

  .proj-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin-top: 0.375rem;
  }

  .proj-links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .proj-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s ease;
    letter-spacing: 0.02em;
  }
  .proj-link:hover {
    color: var(--accent);
  }
</style>
