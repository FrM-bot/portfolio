---
import { getI18n } from '@/i18n'
import SocialLinks from './SocialLinks.astro'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const contact = i18n.Contact
const title = i18n.Translations.sections.title.Contact
---

<section class="flex flex-col gap-8">
  <header class="flex flex-col gap-2.5">
    <span
      class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.75rem] font-medium tracking-[0.09em] text-[var(--text-faint)] uppercase"
    >
      {title}
    </span>
    <span class="block h-px w-full bg-[var(--border)]"></span>
  </header>

  <div class="relative flex flex-col gap-7">
    <address
      class="max-w-[60ch] animate-[fade-up_.65s_cubic-bezier(0.16,1,0.3,1)_both] text-[1.05rem] leading-[1.85] text-[var(--text-muted)] not-italic [animation-delay:.06s] motion-reduce:animate-none [&_a]:inline-flex [&_a]:items-center [&_a]:font-medium [&_a]:transition-colors [&_a]:duration-200 [&_a]:hover:text-[var(--text)]"
      set:html={contact.message}
    />
    <div
      class="animate-[fade-up_.65s_cubic-bezier(0.16,1,0.3,1)_both] border-t border-[var(--border)] pt-5 [animation-delay:.14s] motion-reduce:animate-none"
    >
      <SocialLinks />
    </div>
  </div>
</section>
