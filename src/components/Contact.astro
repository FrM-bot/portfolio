---
import { getI18n } from '@/i18n'
import SocialLinks from './SocialLinks.astro'

const { currentLocale } = Astro
const i18n = getI18n({ lang: currentLocale })
const contact = i18n.Contact
const title = i18n.Translations.sections.title.Contact
---

<section class="flex flex-col gap-6">
  <header class="flex flex-col gap-2.5">
    <span
      class="[font-family:'Jost',ui-sans-serif,system-ui,sans-serif] text-[0.6875rem] font-medium tracking-[0.1em] text-[var(--text-faint)] uppercase"
    >
      {title}
    </span>
    <span class="block h-px w-full bg-[var(--border)]"></span>
  </header>

  <div class="flex flex-col gap-6">
    <address
      class="max-w-[56ch] text-[1.0625rem] leading-7 text-[var(--text-muted)] not-italic [&_a]:font-medium"
      set:html={contact.message}
    />
    <div class="pt-1">
      <SocialLinks />
    </div>
  </div>
</section>
